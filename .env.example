# =============================================================================
# B2C Multi-App Demo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual Azure B2C values.
#
# Naming convention:
#   VITE_APPn_NAME                   — display name for the card
#   VITE_APPn_DESC                   — short description
#   VITE_APPn_{ENV}_TENANT_DOMAIN    — e.g. ecab2cdev.onmicrosoft.com
#   VITE_APPn_{ENV}_CLIENT_ID        — Azure App Registration client ID
#   VITE_APPn_{ENV}_POLICY           — B2C policy, e.g. B2C_1A_SUSI
#   VITE_APPn_{ENV}_SCOPE            — space-separated OIDC scopes
#
# {ENV} is DEV, STAGE, or PROD.
# Leave an env block empty to mark it as "not set" in the UI.
#
# To add a 4th app, copy any APP block, change n→4, and add it to
# src/config/b2cApps.ts B2C_APPS array.
# =============================================================================

# =============================================================================
# APP 1
# =============================================================================
VITE_APP1_NAME="Vendor Hub"
VITE_APP1_DESC="Vendor supplier management portal"

VITE_APP1_DEV_TENANT_DOMAIN=ecab2cdev.onmicrosoft.com
VITE_APP1_DEV_CLIENT_ID=107e293c-0b3c-41b0-9863-c46895fc6a38
VITE_APP1_DEV_POLICY=B2C_1A_ALMARSA_DEV_SUSI
VITE_APP1_DEV_SCOPE=openid profile offline_access

VITE_APP1_STAGE_TENANT_DOMAIN=ecab2ctest.onmicrosoft.com
VITE_APP1_STAGE_CLIENT_ID=9d5d6329-6fa8-42da-8bee-4767fac9e746
VITE_APP1_STAGE_POLICY=B2C_1A_ALMARSA_STG_SUSI
VITE_APP1_STAGE_SCOPE=openid profile offline_access

VITE_APP1_PROD_TENANT_DOMAIN=
VITE_APP1_PROD_CLIENT_ID=
VITE_APP1_PROD_POLICY=
VITE_APP1_PROD_SCOPE=

# =============================================================================
# APP 2
# =============================================================================
VITE_APP2_NAME="Supplier Portal"
VITE_APP2_DESC="External supplier onboarding and management"

VITE_APP2_DEV_TENANT_DOMAIN=
VITE_APP2_DEV_CLIENT_ID=
VITE_APP2_DEV_POLICY=
VITE_APP2_DEV_SCOPE=openid profile offline_access

VITE_APP2_STAGE_TENANT_DOMAIN=
VITE_APP2_STAGE_CLIENT_ID=
VITE_APP2_STAGE_POLICY=
VITE_APP2_STAGE_SCOPE=openid profile offline_access

VITE_APP2_PROD_TENANT_DOMAIN=
VITE_APP2_PROD_CLIENT_ID=
VITE_APP2_PROD_POLICY=
VITE_APP2_PROD_SCOPE=

# =============================================================================
# APP 3
# =============================================================================
VITE_APP3_NAME="Admin Console"
VITE_APP3_DESC="Internal administration and reporting"

VITE_APP3_DEV_TENANT_DOMAIN=
VITE_APP3_DEV_CLIENT_ID=
VITE_APP3_DEV_POLICY=
VITE_APP3_DEV_SCOPE=openid profile offline_access

VITE_APP3_STAGE_TENANT_DOMAIN=
VITE_APP3_STAGE_CLIENT_ID=
VITE_APP3_STAGE_POLICY=
VITE_APP3_STAGE_SCOPE=openid profile offline_access

VITE_APP3_PROD_TENANT_DOMAIN=
